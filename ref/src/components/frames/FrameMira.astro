---
import "./FrameMira.css";
---

<!--
  Mira frame.
  Wicked problem: what makes learning with AI fun for youngsters?
  Mira flips the assistant pattern: she invites creative play
  instead of quizzing. No right answers — just spark + reply.
-->
<div class="sc-card c-mira">
  <div class="sc-status">
    <span class="sc-live-time"></span>
    <div class="sc-dot"></div>
    <div class="sc-status-icons">
      <span class="ms sc-status-ms">wifi</span>
      <span class="ms sc-status-ms">battery_full</span>
    </div>
  </div>
  <div class="mi-header">
    <div class="mi-mascot"></div>
    <div>
      <div class="mi-greet text--1 lh-0">hi there,</div>
      <div class="mi-name text-2 lh-0">Mira here ✨</div>
    </div>
  </div>
  <div class="mi-spark">
    <div class="mi-spark-label text--2 lh-0">today's spark</div>
    <div class="mi-spark-text text-2 lh-2 fw-5">If your shadow could whisper, what would it say?</div>
  </div>
  <div class="mi-replies text--1">
    <div class="mi-reply draw">
      <div class="mi-reply-icon"><span class="ms text-0">brush</span></div>
      <span>draw it</span>
    </div>
    <div class="mi-reply tell">
      <div class="mi-reply-icon"><span class="ms text-0">edit</span></div>
      <span>write a tiny story</span>
    </div>
    <div class="mi-reply sing">
      <div class="mi-reply-icon"><span class="ms text-0">mic</span></div>
      <span>sing it out loud</span>
    </div>
  </div>
  <div class="mi-foot text--1">
    <span>no right answers — promise</span>
    <div class="mi-foot-streak"><span class="ms text--1">favorite</span> 8</div>
  </div>
  <div class="sc-home-bar"></div>
</div>
