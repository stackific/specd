---
import "./FrameEcho.css";
---

<!--
  Echo frame.
  Wicked problem: what creates a lasting positive impact that
  will outlive us? Echo records small generous acts and
  visualizes their downstream ripples — the rings keep
  expanding even after we stop watching.
-->
<div class="sc-card c-echo">
  <div class="sc-status">
    <span class="sc-live-time"></span>
    <div class="sc-dot"></div>
    <div class="sc-status-icons">
      <span class="ms sc-status-ms">wifi</span>
      <span class="ms sc-status-ms">battery_full</span>
    </div>
  </div>
  <div class="ec-header">
    <div class="ec-eyebrow text--2">echo</div>
    <div class="ec-title text-2 lh-2 fw-7">Today, you<br />reached <em>14</em> lives</div>
  </div>
  <div class="ec-ripple">
    <div class="ec-ring r1"></div>
    <div class="ec-ring r2"></div>
    <div class="ec-ring r3"></div>
    <div class="ec-ring r4"></div>
    <div class="ec-center"></div>
  </div>
  <div class="ec-list text--1">
    <div class="ec-row">
      <div class="ec-row-icon"><span class="ms text-0">menu_book</span></div>
      <div class="ec-row-body">
        <div class="ec-row-title lh-2">Lent <em>Heart-centric Design</em> to Adam</div>
        <div class="ec-row-meta text--2">→ she lent it to 2 more</div>
      </div>
    </div>
    <div class="ec-row">
      <div class="ec-row-icon"><span class="ms text-0">school</span></div>
      <div class="ec-row-body">
        <div class="ec-row-title lh-2">Taught Ayesha a bowline knot</div>
        <div class="ec-row-meta text--2">→ already on a sailing trip</div>
      </div>
    </div>
    <div class="ec-row">
      <div class="ec-row-icon"><span class="ms text-0">graphic_eq</span></div>
      <div class="ec-row-body">
        <div class="ec-row-title lh-0">Voice memo for Mom's 70th</div>
        <div class="ec-row-meta text--2">→ shared in family group</div>
      </div>
    </div>
  </div>
  <div class="ec-foot text--1">Some echoes outlive us.</div>
  <div class="sc-home-bar"></div>
</div>
