---
import "$/styles/index.css";
import { siteConfig, buildTitle, organizationJsonLd, websiteJsonLd } from "$/site.config";
import Footer from "$/components/Footer.astro";

interface Props {
  /** Per-page title. Will be wrapped in `siteConfig.titleTemplate`. Omit for the homepage default. */
  title?: string;
  /** Per-page description. Falls back to `siteConfig.description`. */
  description?: string;
  /** Per-page social-share image. Absolute URL or path under /public. Falls back to `siteConfig.ogImage`. */
  image?: string;
  /** Override the page type for og:type (e.g. "article" for blog posts). */
  ogType?: "website" | "article";
  /** Set to `false` to emit a `noindex` robots tag for this page only. */
  indexable?: boolean;
}

const {
  title,
  description = siteConfig.description,
  image = siteConfig.ogImage,
  ogType = "website",
  indexable = siteConfig.indexable,
} = Astro.props;

const documentTitle = buildTitle(title);
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const ogImageURL = new URL(image, Astro.site ?? Astro.url.origin).href;
const robotsContent = indexable ? "index, follow" : "noindex, nofollow";
const orgJsonLd = JSON.stringify(organizationJsonLd());
const siteJsonLd = JSON.stringify(websiteJsonLd());
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
---

<!doctype html>
<html lang={siteConfig.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{documentTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content={siteConfig.themeColor} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={siteConfig.ogLocale} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content={String(siteConfig.ogImageWidth)} />
    <meta property="og:image:height" content={String(siteConfig.ogImageHeight)} />
    <meta property="og:image:alt" content={siteConfig.ogImageAlt} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={siteConfig.ogImageAlt} />
    {siteConfig.twitterHandle && <meta name="twitter:site" content={siteConfig.twitterHandle} />}

    <!-- Icons / PWA -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={orgJsonLd} />
    <script type="application/ld+json" set:html={siteJsonLd} />

    <!-- BeerCSS framework — vendored at public/vendor/beer.min.css to keep it OUT of our bundled custom CSS. See public/vendor/README.md for regen. -->
    <link rel="stylesheet" href="/vendor/beer.min.css" />
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </head>
  <body class="surface">
    <!-- Desktop sidebar: visible on large screens ("l" breakpoint), "max" = expanded by default -->
    <nav class="left l max surface-container" aria-label="Main navigation">
      <header>
        <!-- Collapse/expand sidebar toggle -->
        <button class="circle extra transparent" aria-label="Toggle sidebar" aria-expanded="true">
          <i aria-hidden="true">menu_open</i>
        </button>
        <a href="/" class="transparent" aria-label="Stackific home">
          <img class="logo-light" alt="Stackific logo" width="60" src="/logo.svg" />
          <img class="logo-dark" alt="Stackific logo" width="60" src="/logo-dark.svg" />
        </a>
      </header>
      <!-- Nav links -->
      <a href="/about"><i aria-hidden="true">info</i><span class="fw-5">About</span></a>
      <a href="/services"><i aria-hidden="true">design_services</i><span class="fw-5">Our services</span></a>
      <a data-ui="#contact-dialog" style="cursor:pointer;"><i aria-hidden="true">send</i><span class="fw-5">Work with us</span></a>
      <div class="max"></div>
      <!-- Dark/light toggle for desktop sidebar -->
      <button class="my-2 border circle" aria-label="Toggle dark mode">
        <i class="page bottom active" aria-hidden="true">dark_mode</i>
      </button>
    </nav>

    <!-- Mobile/tablet top bar: visible on small ("s") and medium ("m") screens -->
    <nav class="top s m left-align" aria-label="Mobile navigation">
      <button class="circle transparent" data-ui="#mobile-menu" aria-label="Open menu">
        <i aria-hidden="true">menu</i>
      </button>

      <a href="/" class="circle transparent" aria-label="Stackific home">
        <img class="logo-light" alt="Stackific logo" width="60" src="/logo.svg" />
        <img class="logo-dark" alt="Stackific logo" width="60" src="/logo-dark.svg" />
      </a>

      <div class="max"></div>
      <!-- Dark/light toggle for mobile top bar -->
      <button class="circle border primary-text" aria-label="Toggle dark mode">
        <i class="page top active" aria-hidden="true">dark_mode</i>
      </button>
    </nav>

    <!-- Mobile menu dialog -->
    <dialog id="mobile-menu" class="p-5" aria-label="Mobile menu" style="width:min(360px, 92vw); max-width:none;">
      <nav class="vertical fw-5 text-2">
        <a href="/about"><i aria-hidden="true">info</i><span class="ml-3">About</span></a>
        <a href="/services"><i aria-hidden="true">design_services</i><span class="ml-3">Our services</span></a>
        <a data-ui="#contact-dialog" style="cursor:pointer;"><i aria-hidden="true">send</i><span class="ml-3">Work with us</span></a>
      </nav>
    </dialog>

    <!-- Page content injected here -->
    <slot />

    <Footer />

    <!-- Contact dialog (BeerCSS modal) -->
    <dialog id="contact-dialog" class="modal p-5" aria-labelledby="contact-dialog-title" style="width:min(560px, 92vw); max-width:none;">
      <h2 id="contact-dialog-title" class="text-3 lh-2 fw-7 m-0">Work with us</h2>
      <p class="secondary-text">Tell us a bit about you and we'll be in touch.</p>
      <form id="contact-form" class="mt-3" novalidate>
        <div class="field label border">
          <input type="text" id="cd-name" name="name" autocomplete="name" required />
          <label for="cd-name">Full name</label>
        </div>
        <div class="field label border">
          <input type="email" id="cd-email" name="email" autocomplete="email" required />
          <label for="cd-email">Work email</label>
        </div>
        <div class="field label border">
          <input type="text" id="cd-org" name="organization" autocomplete="organization" required />
          <label for="cd-org">Organization</label>
        </div>
        <div class="field label border">
          <input type="text" id="cd-title" name="position" autocomplete="organization-title" required />
          <label for="cd-title">Title</label>
        </div>
        <div class="field label textarea border">
          <textarea id="cd-message" name="message" rows="4" required></textarea>
          <label for="cd-message">Message</label>
        </div>
        {turnstileSiteKey ? (
          <div id="cd-turnstile" class="cf-turnstile mt-3" data-sitekey={turnstileSiteKey} data-theme="auto"></div>
        ) : (
          <article class="border p-2 mt-3 error" role="alert">
            <p class="small m-0">Captcha is not configured. Set <code>PUBLIC_TURNSTILE_SITE_KEY</code> in your environment.</p>
          </article>
        )}
        <!-- Status box: hidden via the native HTML `hidden` attribute, populated by JS on submit. -->
        <article id="cd-status" class="border p-2 mt-3" role="status" aria-live="polite" style="display:none;">
          <div class="row m-0">
            <i id="cd-status-icon" class="small">info</i>
            <p id="cd-status-text" class="small m-0 lh-0" style="flex:1;"></p>
          </div>
        </article>
        <nav class="right-align mt-3">
          <button type="button" data-ui="#contact-dialog" class="border">Close</button>
          <button type="submit" id="cd-submit">
            <i id="cd-submit-spinner" class="small" style="display:none;">progress_activity</i>
            <span id="cd-submit-label">Submit</span>
          </button>
        </nav>
      </form>
    </dialog>

    <script>
      // BeerCSS CSS is loaded via <link> in <head> from /vendor/beer.min.css.
      // Geist font CSS is bundled by src/styles/index.css.
      // We import BeerCSS's runtime JS DIRECTLY from its compiled file, NOT from
      // the package root. The package's "beercss" entry (index.js) does
      //     import "./dist/cdn/beer.min.css";
      // as a side effect, which would pull BeerCSS back into our LightningCSS
      // bundle and double-load it. Importing the .js file path skips that.
      import { ui } from "beercss/dist/cdn/beer.min.js";
      import "material-dynamic-colors";

      // Set the primary theme color
      ui("theme", "#1c4bea");

      // Restore saved dark/light mode from localStorage
      const saved = localStorage.getItem("mode");
      if (saved) ui("mode", saved);

      // Toggle dark/light mode on click (both desktop and mobile buttons use i.page)
      document.querySelectorAll("button:has(> i.page)").forEach((btn) => {
        btn.addEventListener("click", () => {
          const current = ui("mode");
          const next = current === "dark" ? "light" : "dark";
          ui("mode", next);
          localStorage.setItem("mode", next);
          document.querySelectorAll("button:has(> i.page) > i").forEach((i) => {
            i.textContent = next === "dark" ? "light_mode" : "dark_mode";
          });
        });
      });

      // Sync icon text with current mode on page load
      const mode = ui("mode");
      document.querySelectorAll("button:has(> i.page) > i").forEach((i) => {
        i.textContent = mode === "dark" ? "light_mode" : "dark_mode";
      });

      // Contact form submission: client-side validation, Turnstile token, POST /api/contact
      const contactForm = document.getElementById("contact-form") as HTMLFormElement | null;
      const statusBox = document.getElementById("cd-status");
      const statusIcon = document.getElementById("cd-status-icon");
      const statusText = document.getElementById("cd-status-text");
      function setStatus(kind: "info" | "success" | "error", msg: string) {
        if (!statusBox || !statusIcon || !statusText) return;
        statusBox.classList.remove("tertiary-container", "error", "secondary-container");
        (statusBox as HTMLElement).style.display = "";
        statusText.textContent = msg;
        if (kind === "success") {
          statusBox.classList.add("tertiary-container");
          statusIcon.textContent = "check_circle";
        } else if (kind === "error") {
          statusBox.classList.add("error");
          statusIcon.textContent = "error";
        } else {
          statusBox.classList.add("secondary-container");
          statusIcon.textContent = "info";
        }
      }
      const submitBtn = document.getElementById("cd-submit") as HTMLButtonElement | null;
      const submitSpinner = document.getElementById("cd-submit-spinner");
      const submitLabel = document.getElementById("cd-submit-label");
      function setBusy(busy: boolean) {
        if (submitBtn) submitBtn.disabled = busy;
        if (submitSpinner) (submitSpinner as HTMLElement).style.display = busy ? "" : "none";
        if (submitSpinner) submitSpinner.classList.toggle("is-rotating", busy);
        if (submitLabel) submitLabel.textContent = busy ? "Sending…" : "Submit";
      }
      if (contactForm) {
        contactForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          if (!contactForm.reportValidity()) return;
          const data = new FormData(contactForm);
          const ts = (window as unknown as { turnstile?: { getResponse: (el: Element) => string | undefined } }).turnstile;
          const widget = document.getElementById("cd-turnstile");
          if (!widget) {
            setStatus("error", "Captcha is not configured. Please contact us directly at info@stackific.com.");
            return;
          }
          let token = "";
          try {
            token = (ts && widget ? ts.getResponse(widget) : "") || "";
          } catch {
            token = "";
          }
          if (!token) {
            setStatus("error", "Please complete the captcha challenge before submitting.");
            return;
          }
          setStatus("info", "Sending your message…");
          setBusy(true);
          try {
            const res = await fetch("/api/contact", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({
                name: data.get("name"),
                email: data.get("email"),
                organization: data.get("organization"),
                position: data.get("position"),
                message: data.get("message"),
                turnstileToken: token,
              }),
            });
            const body = (await res.json().catch(() => ({}))) as { error?: string };
            if (res.ok) {
              setStatus("success", "Thanks — we'll be in touch shortly.");
              contactForm.reset();
              const tsReset = (window as unknown as { turnstile?: { reset: (el: Element) => void } }).turnstile;
              if (tsReset && widget) tsReset.reset(widget);
            } else {
              setStatus("error", body.error || "Something went wrong. Please try again.");
            }
          } catch {
            setStatus("error", "Network error. Please try again.");
          } finally {
            setBusy(false);
          }
        });
      }

      // Sidebar collapse/expand toggle with localStorage persistence
      const leftNav = document.querySelector("nav.left");
      if (leftNav) {
        const savedNav = localStorage.getItem("nav-collapsed");
        const menuBtn = leftNav.querySelector("button[aria-label='Toggle sidebar']");
        const menuIcon = menuBtn ? menuBtn.querySelector("i") : null;
        if (savedNav === "true") {
          leftNav.classList.remove("max");
          if (menuBtn) menuBtn.setAttribute("aria-expanded", "false");
          if (menuIcon) menuIcon.textContent = "menu";
        }

        if (menuBtn) {
          menuBtn.addEventListener("click", () => {
            const collapsed = leftNav.classList.toggle("max") === false;
            localStorage.setItem("nav-collapsed", String(collapsed));
            menuBtn.setAttribute("aria-expanded", String(!collapsed));
            if (menuIcon) menuIcon.textContent = collapsed ? "menu" : "menu_open";
          });
        }
      }
    </script>
  </body>
</html>
